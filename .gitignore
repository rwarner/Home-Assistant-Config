# You can whitelist files/folders with !, these will not be ignored.
!*.yaml
!.gitignore
!*.md
!*.sh

# Ignore folders
.storage
.cloud
.google.token
.vscode
backup/
backups/
image/
tts/
blueprints/
deps/

# Ensure these YAML files are ignored, otherwise your secret data/credentials will leak.
ip_bans.yaml
secrets.yaml
known_devices.yaml

# DB Files or special files
*.bak
*.conf
*.log
*.db
*.db*
*.sqlite
home-assistant.log.*

# Alexa media
*.pickle

# Specific Files
.HA_VERSION
.uuid
.python-version

# Go 2 RTC
go2rtc*

# Ignore community plugins
www/**
custom_components/
custom_icons/

# But allow the images folder and all files in it
!www/images/
!www/images/**

.ha_run.lock

# Claude Code
CLAUDE.md
.claude/
docs/plans/
